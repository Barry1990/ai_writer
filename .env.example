# OpenAI 配置
OPENAI_API_KEY=your_openai_api_key_here
# OpenAI Base URL (如果后面写了值则使用，没写则用官方默认地址)
OPENAI_BASE_URL=
# OpenAI 默认模型 (如 gpt-4o, gpt-3.5-turbo 等)
OPENAI_MODEL=gpt-4o

# Gemini 配置
GEMINI_API_KEY=your_gemini_api_key_here
# Gemini Base URL (如果后面写了值则使用，没写则用官方默认地址)
GEMINI_BASE_URL=
# Gemini 默认模型 (如 gemini-1.5-pro, gemini-3-flash-preview 等)
GEMINI_MODEL=gemini-3-flash-preview
